{
  "name": "ruru-spotify-mcp",
  "version": "0.3.0",
  "description": "MCP server for Spotify Web API — control playback, search, and manage playlists by name, no IDs exposed",
  "type": "module",
  "bin": {
    "ruru-spotify-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/*.js",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "tsx --test src/**/*.test.ts",
    "check": "biome check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
